// ============================================================
// PAYMENT MODEL - Transaction Management
// ============================================================

model Payment {
    id String @id @default(uuid(7))
    
    // Payment Amount
    amount Float
    
    // Transaction Details
    transactionId      String    @unique
    paymentGateway     String?   // e.g., "stripe", "paypal", "bkash"
    paymentMethod      String?   // e.g., "credit_card", "mobile_wallet"
    paymentGatewayData Json?     // Store additional gateway-specific data
    
    // Status
    status             PaymentStatus @default(UNPAID)
    
    // Status & Timestamps
    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt

    // Optional reference to appointment (if needed for medical features)
    // appointmentId String @unique
    // appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

    @@index([transactionId], name: "idx_payment_transactionId")
    @@index([status], name: "idx_payment_status")
    @@map("payments")
}